# Gemini LLM API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_THINKING_LEVEL=low

# Groq LLM API (disabled — kept for reference)
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=openai/gpt-oss-120b
# GROQ_REASONING_EFFORT=low

# Telegram Bot (https://bot.telegram.io)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=@your_channel_name

# Email SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your-email@gmail.com
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# ChromaDB storage path
CHROMADB_PATH=./outputs/chroma_db

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console
TIMEZONE=Asia/Kolkata

# Collector settings
MAX_CONCURRENT_REQUESTS=10
RATE_LIMIT_SECONDS=0.5
REDDIT_RATE_LIMIT_SECONDS=2.5
HTTP_TIMEOUT_SECONDS=10
MAX_ARTICLES_PER_SOURCE=50
MAX_RETRIES=3

# Deduplication
SIMILARITY_THRESHOLD=0.85
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1
EMBEDDING_BATCH_SIZE=32

# Ranker
TOP_ARTICLES_COUNT=20

# Writer (Gemini)
GEMINI_MAX_INPUT_TOKENS=32000
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=4
GEMINI_RETRY_BASE_SECONDS=2.0
WRITER_MAX_ARTICLES=12
WRITER_MAX_SUMMARY_CHARS=280
WRITER_SUMMARY_CHAR_STEPS=280,200,140,100,80

# Pipeline checkpoint / resume (LangGraph + JSON snapshots)
PIPELINE_MODE=auto
# PIPELINE_FROM_NODE=writer
# PIPELINE_THREAD_ID=pipeline-2026-06-25
PIPELINE_CHECKPOINT_DB=./outputs/checkpoints/pipeline.db
PIPELINE_SNAPSHOT_DIR=./outputs/pipeline_state
